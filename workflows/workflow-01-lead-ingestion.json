{
  "name": "workflow-01-lead-ingestion",
  "nodes": [
    {
      "id": "w01-node-01",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "lead-ingestion",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "w01-node-02",
      "name": "Respond 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [450, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"received\": true } }}"
      }
    },
    {
      "id": "w01-node-03",
      "name": "Wait 10s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [650, 300],
      "parameters": {
        "amount": 10,
        "unit": "seconds"
      }
    },
    {
      "id": "w01-node-04",
      "name": "Create Retell Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [850, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.retellai.com/v2/create-phone-call",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "=JSON.stringify({ from_number: $vars.RETELL_FROM_NUMBER, to_number: $json.phone, agent_id: $vars.RETELL_AGENT_ID, metadata: { lead_id: $json.lead_id }, retell_llm_dynamic_variables: { lead_name: $json.first_name, dental_need: ($json.dental_needs ?? [])[0] ?? '', timeline: $json.preferred_timeline ?? '', budget: $json.estimated_budget ?? '' } })"
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "retell-api-cred",
          "name": "RetellAI-API"
        }
      }
    },
    {
      "id": "w01-node-05",
      "name": "Update Lead Status",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1050, 300],
      "parameters": {
        "operation": "update",
        "tableId": "leads",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "keyValue": "={{ $('Webhook1').item.json.body.lead_id }}"
            }
          ]
        },
        "dataToSend": "defineBelow",
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "status",
              "fieldValue": "call_scheduled"
            }
          ]
        }
      },
      "credentials": {
        "supabaseApi": {
          "id": "supabase-api-cred",
          "name": "Supabase-API"
        }
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [{ "node": "Respond 200", "type": "main", "index": 0 }]
      ]
    },
    "Respond 200": {
      "main": [
        [{ "node": "Wait 10s", "type": "main", "index": 0 }]
      ]
    },
    "Wait 10s": {
      "main": [
        [{ "node": "Create Retell Call", "type": "main", "index": 0 }]
      ]
    },
    "Create Retell Call": {
      "main": [
        [{ "node": "Update Lead Status", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null
}
