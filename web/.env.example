# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# Retell AI
RETELL_API_KEY=your-retell-api-key
RETELL_AGENT_ID=your-agent-id
RETELL_FROM_NUMBER=+1XXXXXXXXXX

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# TrustedForm (optional — gracefully degrades if absent)
TRUSTEDFORM_API_KEY=your-trustedform-key

# n8n Webhooks (set after importing workflows into your n8n instance)
N8N_LEAD_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/lead-ingestion
N8N_POSTCALL_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/post-call-routing
N8N_SMS_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/sms-followup

# Dashboard access (protect /dashboard — append ?secret=VALUE to URL, validated server-side)
DASHBOARD_SECRET=change-me-before-deploy

# Founder alert (receives hot lead SMS notifications)
FOUNDER_PHONE=+1XXXXXXXXXX

# App URL (used for internal API calls from orchestrator)
NEXT_PUBLIC_APP_URL=http://localhost:3000
