  "routing_rules": {
    "default_channel": "email",
    "description": "Rules for routing leads to contact channels based on characteristics",
    "rules": [
      {
        "name": "hot_lead_call_immediately",
        "condition": "lead_score >= 80 AND call_consent = true AND business_hours = true",
        "action": "route_to_voice_agent_immediately",
        "priority": 1
      },
      {
        "name": "hot_lead_call_voicemail",
        "condition": "lead_score >= 80 AND call_consent = true AND business_hours = false",
        "action": "route_to_voicemail_agent",
        "priority": 2
      },
      {
        "name": "warm_lead_sms_first",
        "condition": "lead_score >= 70 AND lead_score < 80 AND sms_consent = true",
        "action": "route_to_sms_agent",
        "priority": 3
      },
      {
        "name": "warm_lead_email_callback",
        "condition": "lead_score >= 50 AND lead_score < 70 AND email_consent = true",
        "action": "route_to_email_agent_with_callback_offer",
        "priority": 4
      },
      {
        "name": "cold_lead_nurture",
        "condition": "lead_score < 50 AND email_consent = true",
        "action": "route_to_automated_nurture_sequence",
        "priority": 5
      },
      {
        "name": "opted_out",
        "condition": "opt_in_status = 'opted_out'",
        "action": "do_not_contact",
        "priority": -1
      },
      {
        "name": "insufficient_consent",
        "condition": "call_consent = false AND sms_consent = false AND email_consent = false",
        "action": "hold_for_consent_acquisition",
        "priority": -1
      }
    ]
  },

