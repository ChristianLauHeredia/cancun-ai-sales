  "optimal_contact_times": {
    "timezone_adjusted": true,
    "description": "Optimal times to contact leads based on score and lead behavior patterns",
    "preferred_times": {
      "for_calls": {
        "hot_leads": "immediately_if_business_hours",
        "warm_leads_morning": "0700_0900",
