{
  "schema_version": "1.0.0",
  "description": "Rule engine for lead contact decisions. Provides fallback rules when AI orchestrator is unavailable, and configuration for rate limiting and business logic.",
  "metadata": {
    "organization": "Cancun Dental Partners",
    "created_at": "2024-01-01T00:00:00Z",
    "last_updated": "2024-01-01T00:00:00Z",
    "maintainer": "AI Operations"
  },

  "business_hours": {
    "start": "09:00",
    "end": "20:00",
    "timezone": "America/Chicago",
    "description": "Hours when outbound calls should be initiated. SMS and email can be sent anytime but best response rates during these hours."
  },

  "contact_limits": {
    "max_call_attempts": 3,
    "max_sms_per_day": 2,
    "max_emails_per_day": 2,
    "call_cooldown_hours": 24,
    "call_attempt_gap_hours": 2,
    "sms_cooldown_hours": 4,
    "email_cooldown_hours": 24,
    "max_contacts_per_day": 5,
    "max_contacts_per_week": 15,
    "pause_after_no_response_attempts": 3,
    "pause_duration_days": 7,
    "description": "Rate limiting to prevent contact fatigue and ensure TCPA compliance."
  },

  "lead_score_bands": {
    "hot": {
      "range": [80, 100],
      "primary_channel": "phone",
      "call_priority": "immediate",
      "sms_cadence": "as_backup",
      "email_cadence": "transactional_only",
      "max_response_time_minutes": 5,
      "description": "Highly qualified, ready to buy, immediate action"
    },
    "warm": {
      "range": [50, 79],
      "primary_channel": "sms",
      "secondary_channel": "phone",
      "call_priority": "same_day",
      "sms_cadence": "immediate",
      "email_cadence": "follow_up_24h",
      "max_response_time_minutes": 120,
      "description": "Interested with some hesitation, nurture and test"
    },
    "cool": {
      "range": [30, 49],
      "primary_channel": "email",
      "secondary_channel": "sms",
      "call_priority": "avoid",
      "sms_cadence": "wait_48h",
      "email_cadence": "educational_content",
      "max_response_time_minutes": 1440,
      "description": "Curiosity-driven, informational needs"
    },
    "cold": {
      "range": [1, 29],
      "primary_channel": "email",
      "secondary_channel": "none",
      "call_priority": "never",
      "sms_cadence": "never",
      "email_cadence": "automated_nurture_weekly",
      "max_response_time_minutes": 2880,
      "description": "Early stage, automated nurture only"
    }
  },

