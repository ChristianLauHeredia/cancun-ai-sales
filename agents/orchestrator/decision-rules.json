  "hot_lead_response_targets": {
    "initial_contact_time_minutes": 5,
    "follow_up_if_no_answer_minutes": 120,
    "max_time_to_coordinator_transfer_minutes": 60,
    "description": "Hot leads must be contacted within very short timeframes to maximize conversion"
  },

  "tcpa_compliance_rules": {
    "version": "2024",
    "critical": true,
    "description": "TCPA (Telephone Consumer Protection Act) compliance requirements. Failure to comply results in legal liability.",
    "consent_requirements": {
      "calls": {
        "prior_express_consent": true,
        "written_agreement_required": true,
        "revocation_honored": true,
        "do_not_call_registry_checked": true,
        "description": "Must have explicit prior written consent for calls"
      },
      "sms": {
        "prior_express_consent": true,
        "opt_in_confirmation": true,
        "revocation_honored": true,
        "description": "Must have explicit opt-in for SMS"
      },
      "email": {
        "prior_express_consent": false,
        "can_assume_consent": true,
        "revocation_honored": true,
        "unsubscribe_required": true,
        "description": "Email has most lenient requirements but must provide unsubscribe"
      }
    },
    "contact_time_restrictions": {
      "calls_allowed_hours": "0800_2100",
      "sms_allowed_hours": "0800_2100",
      "timezone": "recipient_local_time",
      "weekends_allowed": false,
      "holidays_allowed": false
    },
    "do_not_call_checklist": [
      "Lead on national do-not-call registry?",
      "Lead explicitly requested do-not-call?",
      "Company do-not-call list checked?",
      "State-specific do-not-call list checked?",
      "Lead has active opt-out from previous campaign?"
    ],
    "safe_harbor_procedures": {
      "maintain_internal_dnc_list": true,
      "update_frequency": "daily",
      "honor_opt_outs_within": "24_hours",
      "document_all_consent": true,
      "retain_records": "4_years"
    }
  },

